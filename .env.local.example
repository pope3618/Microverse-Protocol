# Microverse Protocol — 链上地址配置（均为公开测试网参数，无密钥）
# 复制为 .env.local 后按需修改；部署到 Vercel 时请在环境变量面板配置同名变量。

# Sepolia 真实测试 USDT（Tether 官方 USDT0，6 位小数）
# 水龙头：Etherscan 自助 _mint（见 USDT_FAUCET_URL）
NEXT_PUBLIC_USDT_ADDRESS=0xc4DCC311c028e341fd8602D8eB89c5de94625927

# 测试 USDT 自助水龙头入口
NEXT_PUBLIC_USDT_FAUCET_URL=https://sepolia.etherscan.io/token/0xc4DCC311c028e341fd8602D8eB89c5de94625927#writeContract

# 收益合约地址（可选）。
# 配置后收益页读取真实 earnings(address) 并调用 claim()；
# 留空则走演示逻辑（展示真实链上余额 + 演示可领取额）。
# NEXT_PUBLIC_REWARDS_ADDRESS=0xYourRewardsContractAddress
